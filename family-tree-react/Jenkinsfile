// CI for the React frontend. Runs on Calculon, triggered AFTER the API job
// (family-tree-ci) builds successfully.
//
//   Build React  -> Deploy & E2E (Postgres + API + React + Playwright @ :4202)
//
// Auth-light: the API runs on the 'e2e' profile (lazy jwk-set-uri, no Keycloak), so
// /api/** calls 401 and the render smoke test tolerates it. Data-driven e2e comes
// once React does Keycloak.
pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    triggers {
        upstream(upstreamProjects: 'family-tree-ci', threshold: hudson.model.Result.SUCCESS)
    }

    environment {
        REGISTRY     = '192.168.0.186:5001'
        IMAGE        = 'family-tree-react'
        CHART_VALUES = 'gitops/charts/react/values.yaml'
    }

    stages {
        stage('Build React') {
            steps {
                dir('family-tree-react') {
                    sh 'npm ci'
                    sh 'npm run build'
                }
            }
        }

        stage('Deploy & E2E') {
            steps {
                sh '''
                    set -e
                    API_PID=""; WEB_PID=""
                    cleanup() {
                      kill $API_PID $WEB_PID 2>/dev/null || true
                      pkill -f "family-tree-app-.*\\.jar" 2>/dev/null || true
                      pkill -f "vite preview" 2>/dev/null || true
                      docker rm -f ft-e2e-db >/dev/null 2>&1 || true
                    }
                    trap cleanup EXIT

                    echo "--- Postgres ---"
                    docker rm -f ft-e2e-db >/dev/null 2>&1 || true
                    docker run -d --name ft-e2e-db \
                      -e POSTGRES_DB=familytree -e POSTGRES_USER=familytree -e POSTGRES_PASSWORD=familytree \
                      -p 5432:5432 postgres:16
                    for i in $(seq 1 30); do docker exec ft-e2e-db pg_isready -U familytree >/dev/null 2>&1 && break; sleep 2; done

                    echo "--- Build + start API (profile e2e) ---"
                    ( cd family-tree-app && mvn -q -B -ntp -DskipTests package )
                    JAR=$(ls family-tree-app/target/family-tree-app-*.jar | grep -v original | head -1)
                    SPRING_PROFILES_ACTIVE=e2e DB_HOST=localhost DB_PORT=5432 DB_NAME=familytree \
                      DB_USER=familytree DB_PASSWORD=familytree PORT=3200 \
                      java -jar "$JAR" > api.log 2>&1 &
                    API_PID=$!
                    for i in $(seq 1 60); do curl -sf http://localhost:3200/login >/dev/null 2>&1 && { echo "API up"; break; }; sleep 2; done

                    echo "--- Serve built React on :4202 ---"
                    ( cd family-tree-react && npx vite preview --port 4202 > ../web.log 2>&1 ) &
                    WEB_PID=$!
                    for i in $(seq 1 30); do curl -s -o /dev/null http://localhost:4202/ && { echo "Web up"; break; }; sleep 2; done

                    echo "--- Playwright e2e ---"
                    npm ci || npm install
                    npx playwright install chromium
                    npx playwright test --config playwright.react.config.js
                '''
            }
        }

        // ---- CD: build the image and let ArgoCD redeploy via a GitOps tag bump ----
        // (prereqs: see gitops/ci/README.md — insecure registry on Calculon Docker,
        //  'github-token' credential, ignore-committer loop guard)
        stage('Build & Push image') {
            when { branch 'main' }
            steps {
                script { env.GIT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim() }
                dir('family-tree-react') {
                    sh 'docker build -t $REGISTRY/$IMAGE:$GIT_SHA -t $REGISTRY/$IMAGE:latest .'
                    sh 'docker push $REGISTRY/$IMAGE:$GIT_SHA'
                    sh 'docker push $REGISTRY/$IMAGE:latest'
                }
            }
        }

        stage('Deploy (GitOps tag bump)') {
            when { branch 'main' }
            steps {
                sh '''
                    sed -i -E "s|^(  tag: ).*|\\1$GIT_SHA|" $CHART_VALUES
                    git config user.email "jenkins@calculon"
                    git config user.name "Calculon Jenkins"
                    git add $CHART_VALUES
                    git commit -m "ci(react): deploy $GIT_SHA [skip ci]" || { echo "image.tag unchanged"; exit 0; }
                '''
                withCredentials([usernamePassword(credentialsId: 'github-token',
                        usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
                    sh 'git push https://$GH_USER:$GH_TOKEN@github.com/chrisworth75/dev-familytree.git HEAD:main'
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'api.log,web.log,playwright-report/**', allowEmptyArchive: true
            // Browsable report on the build page (screenshots + video on failed tests).
            publishHTML(target: [
                reportName: 'Playwright E2E Report',
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }
    }
}
