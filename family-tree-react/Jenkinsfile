// CI for the React frontend. Runs on Calculon, triggered after family-tree-ci.
//
//   E2E (full stack via Compose: Postgres + Keycloak + API + React + seed)
//     -> data-driven Playwright: real Keycloak login -> seeded data -> a family
//   Build & Push image  ->  Deploy (GitOps tag bump, main only)
//
// Brings up an ephemeral stack (project ft-e2e, reusing the tier-1 compose) so the
// test exercises the REAL auth path — not the old render smoke test, which is now
// broken by React's login-required redirect.
pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    triggers {
        upstream(upstreamProjects: 'family-tree-ci', threshold: hudson.model.Result.SUCCESS)
    }

    environment {
        REGISTRY     = '192.168.0.186:5001'
        IMAGE        = 'family-tree-react'
        CHART_VALUES = 'gitops/charts/react/values.yaml'
        COMPOSE      = 'docker compose -p ft-e2e -f deploy/tier1-local/compose.yml'
    }

    stages {
        stage('E2E (full stack + real login)') {
            steps {
                sh '''
                    set -e
                    cleanup() { $COMPOSE down -v >/dev/null 2>&1 || true; }
                    trap cleanup EXIT

                    echo "--- bring up ephemeral stack (ft-e2e) ---"
                    $COMPOSE up -d --build

                    echo "--- wait for API, Keycloak, and the one-shot seed ---"
                    for i in $(seq 1 80); do curl -sf http://localhost:13200/actuator/health >/dev/null 2>&1 && break; sleep 3; done
                    for i in $(seq 1 40); do curl -sf http://localhost:18081/realms/family-tree >/dev/null 2>&1 && break; sleep 2; done
                    $COMPOSE wait seed || true

                    echo "--- data-driven Playwright ---"
                    npm ci
                    npx playwright install chromium
                    BASE_URL=http://localhost:14202 npx playwright test --config playwright.react.config.js
                '''
            }
        }

        stage('Build & Push image') {
            when { branch 'main' }
            steps {
                script { env.GIT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim() }
                dir('family-tree-react') {
                    sh 'docker build -t $REGISTRY/$IMAGE:$GIT_SHA -t $REGISTRY/$IMAGE:latest .'
                    sh 'docker push $REGISTRY/$IMAGE:$GIT_SHA'
                    sh 'docker push $REGISTRY/$IMAGE:latest'
                }
            }
        }

        stage('Deploy (GitOps tag bump)') {
            when { branch 'main' }
            steps {
                sh '''
                    sed -i -E "s|^(  tag: ).*|\\1$GIT_SHA|" $CHART_VALUES
                    git config user.email "jenkins@calculon"
                    git config user.name "Calculon Jenkins"
                    git add $CHART_VALUES
                    git commit -m "ci(react): deploy $GIT_SHA [skip ci]" || { echo "image.tag unchanged"; exit 0; }
                '''
                withCredentials([usernamePassword(credentialsId: 'github-token',
                        usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
                    sh 'git push https://$GH_USER:$GH_TOKEN@github.com/chrisworth75/dev-familytree.git HEAD:main'
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'playwright-report/**,test-results/**', allowEmptyArchive: true
            // Browsable report (screenshots + video on failure) on the build page.
            publishHTML(target: [
                reportName: 'Playwright E2E Report',
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }
    }
}
