// Tier 2 CD — the "Jenkins-polls-git GitOps-lite" strategy.
// Polls main; on a change, rebuilds + redeploys the Compose stack on Calculon.
// Push-based: rollback = git revert; no drift self-heal (that's tier 3 / ArgoCD).
// Runs on the Calculon agent; the Jenkins workspace IS the checkout, so the
// compose build contexts (../../family-tree-app, etc.) resolve against the repo.
pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '15'))
    }

    triggers {
        pollSCM('* * * * *')   // every minute
    }

    stages {
        stage('Deploy (Compose tier 2)') {
            steps {
                sh 'docker compose -p ft-t2 -f deploy/tier2-cd/compose.yml up -d --build --remove-orphans'
            }
        }
        stage('Smoke') {
            steps {
                sh '''
                    # Browser-facing ports are HTTPS via the TLS edge now; -k because
                    # Calculon's curl doesn't trust the mkcert CA (the Mac browser does).
                    for i in $(seq 1 30); do
                      curl -fsk https://localhost:23200/actuator/health >/dev/null && { echo "tier2 api UP (https)"; break; }
                      sleep 3
                    done
                    curl -sk -o /dev/null -w "react HTTPS %{http_code}\\n" https://localhost:24202/
                    curl -sk -o /dev/null -w "keycloak HTTPS %{http_code}\\n" https://localhost:28081/realms/family-tree
                '''
            }
        }
    }
}
